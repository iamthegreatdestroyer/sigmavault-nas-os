#!/usr/bin/make -f
# -*- makefile -*-

#export DH_VERBOSE=1

%:
	dh $@

override_dh_auto_clean:
	rm -rf build/
	rm -rf *.egg-info/
	find . -name '*.pyc' -delete
	find . -name '__pycache__' -type d -exec rm -rf {} + || true

override_dh_auto_configure:
	@echo "No configure step needed"

override_dh_auto_build:
	@echo "No build step needed (pure Python)"

override_dh_auto_test:
	@echo "Skipping tests (requires GTK runtime)"

override_dh_auto_install:
	# Install Python package
	install -d debian/sigmavault-desktop/usr/lib/python3/dist-packages/
	cp -r src/desktop-ui/sigmavault_desktop debian/sigmavault-desktop/usr/lib/python3/dist-packages/

	# Install launcher script
	install -d debian/sigmavault-desktop/usr/bin/
	install -m 755 debian/sigmavault-desktop.sh debian/sigmavault-desktop/usr/bin/sigmavault-desktop

	# Install CSS stylesheet
	install -d debian/sigmavault-desktop/usr/share/sigmavault-desktop/
	install -m 644 src/desktop-ui/sigmavault_desktop/data/style.css debian/sigmavault-desktop/usr/share/sigmavault-desktop/

override_dh_installdocs:
	dh_installdocs
	install -d debian/sigmavault-desktop/usr/share/doc/sigmavault-desktop/
	[ -f src/desktop-ui/README.md ] && install -m 644 src/desktop-ui/README.md debian/sigmavault-desktop/usr/share/doc/sigmavault-desktop/ || true
