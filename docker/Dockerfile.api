FROM golang:1.25-alpine AS builder

WORKDIR /app

# Download deps first (layer cache)
COPY src/api/go.mod src/api/go.sum ./
RUN go mod download

# Build
COPY src/api/ .
RUN CGO_ENABLED=0 GOOS=linux go build -o /sigmavault-api .

FROM alpine:3.20

RUN apk add --no-cache wget ca-certificates

COPY --from=builder /sigmavault-api /sigmavault-api

EXPOSE 12080

CMD ["/sigmavault-api"]
